{
  "version": "0.2.27",
  "description": "CLI for managing m8t-stack deployments on Azure / Microsoft Agent Foundry",
  "homepage": "https://github.com/m8t-labs/m8t",
  "license": "MIT",
  "depends": "nodejs",
  "url": "https://registry.npmjs.org/@m8t-stack/cli/-/cli-0.2.27.tgz",
  "hash": "sha256:2932d39dfa8579c0dbcc209845298dfd44cff10cc51b3fcf9c488e72566e8a34",
  "extract_dir": "package",
  "installer": {
    "script": [
      "$ErrorActionPreference = 'Continue'",
      "Push-Location \"$dir\"",
      "npm pkg delete devDependencies 2>&1 | Out-Null",
      "npm install --omit=dev --no-package-lock --no-audit --no-fund 2>&1 | Out-Null",
      "if ($LASTEXITCODE -ne 0) { throw \"npm install failed (exit $LASTEXITCODE)\" }",
      "Pop-Location"
    ]
  },
  "bin": [
    [
      "dist\\cli.js",
      "m8t"
    ]
  ],
  "checkver": {
    "url": "https://registry.npmjs.org/@m8t-stack/cli/latest",
    "jsonpath": "$.version"
  },
  "autoupdate": {
    "url": "https://registry.npmjs.org/@m8t-stack/cli/-/cli-$version.tgz"
  }
}
